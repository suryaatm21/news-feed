{
  "name": "git-populate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.4.1"
  },
  "scripts": {
    "generate:daily": "node --import=tsx scripts/generate-daily.ts",
    "build": "node --import=tsx scripts/build-site.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import=tsx --test test/**/*.test.ts",
    "ci": "npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
